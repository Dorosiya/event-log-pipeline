          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CONCAT('강의-', course_id) AS course_name, ROUND(SUM(CASE WHEN event_type = 'lesson_complete' AND event_status = 'success' THEN 1 ELSE 0 END) / NULLIF(SUM(CASE WHEN event_type = 'course_enroll' AND event_status = 'success' THEN 1 ELSE 0 END), 0) * 100, 2) AS completion_rate FROM event_log WHERE course_id IS NOT NULL GROUP BY course_id HAVING SUM(CASE WHEN event_type = 'course_enroll' AND event_status = 'success' THEN 1 ELSE 0 END) > 0 ORDER BY SUM(CASE WHEN event_type = 'course_enroll' AND event_status = 'success' THEN 1 ELSE 0 END) DESC, completion_rate DESC LIMIT 10",
