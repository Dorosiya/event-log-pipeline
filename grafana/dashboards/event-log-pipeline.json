          "rawQuery": true,
          "rawSql": "SELECT CASE event_type WHEN 'course_view' THEN '강의 조회' WHEN 'course_enroll' THEN '수강 등록' WHEN 'lesson_start' THEN '수강 시작' WHEN 'lesson_complete' THEN '수강 완료' WHEN 'question_create' THEN '질문 등록' ELSE event_type END AS event_type, COUNT(*) AS event_count FROM event_log GROUP BY event_type ORDER BY event_count DESC",
