      },
      "targets": [
        {
          "dataset": "default",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH session_flags AS ( SELECT session_id, MAX(CASE WHEN event_type = 'course_view' AND event_status = 'success' THEN 1 ELSE 0 END) AS has_course_view, MAX(CASE WHEN event_type = 'course_enroll' AND event_status = 'success' THEN 1 ELSE 0 END) AS has_course_enroll, MAX(CASE WHEN event_type = 'lesson_start' AND event_status = 'success' THEN 1 ELSE 0 END) AS has_lesson_start, MAX(CASE WHEN event_type = 'lesson_complete' AND event_status = 'success' THEN 1 ELSE 0 END) AS has_lesson_complete FROM event_log GROUP BY session_id ) SELECT * FROM ( SELECT 1 AS '단계 순서', '강의 조회' AS '단계', COALESCE(SUM(has_course_view), 0) AS '세션 수', 100.0 AS '전환율(%)' FROM session_flags UNION ALL SELECT 2 AS '단계 순서', '수강 등록' AS '단계', COALESCE(SUM(has_course_enroll), 0) AS '세션 수', COALESCE(ROUND(COALESCE(SUM(has_course_enroll), 0) / NULLIF(COALESCE(SUM(has_course_view), 0), 0) * 100, 2), 0) AS '전환율(%)' FROM session_flags UNION ALL SELECT 3 AS '단계 순서', '수강 시작' AS '단계', COALESCE(SUM(has_lesson_start), 0) AS '세션 수', COALESCE(ROUND(COALESCE(SUM(has_lesson_start), 0) / NULLIF(COALESCE(SUM(has_course_view), 0), 0) * 100, 2), 0) AS '전환율(%)' FROM session_flags UNION ALL SELECT 4 AS '단계 순서', '수강 완료' AS '단계', COALESCE(SUM(has_lesson_complete), 0) AS '세션 수', COALESCE(ROUND(COALESCE(SUM(has_lesson_complete), 0) / NULLIF(COALESCE(SUM(has_course_view), 0), 0) * 100, 2), 0) AS '전환율(%)' FROM session_flags ) funnel ORDER BY `단계 순서`",
          "refId": "A"
        }
      ],
      "title": "퍼널 전환 현황",
      "type": "table"
